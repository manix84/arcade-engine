{
  "name": "arcade-engine",
  "description": "A small browser arcade-game engine for canvas games.",
  "version": "4.6.0",
  "license": "MIT",
  "readmeFilename": "README.md",
  "type": "module",
  "author": "Rob Taylor",
  "homepage": "https://manix84.github.io/arcade-engine",
  "bugs": {
    "url": "https://github.com/manix84/arcade-engine/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manix84/arcade-engine.git"
  },
  "keywords": [
    "arcade",
    "browser",
    "canvas",
    "game-engine",
    "typescript"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc --project tsconfig.build.json && node scripts/validate-package.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "pack:release": "node scripts/pack-release.mjs",
    "prepack": "npm run build && node scripts/prepare-package-readme.mjs apply",
    "postpack": "node scripts/prepare-package-readme.mjs restore",
    "precommit": "node scripts/pre-commit.mjs",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o storybook-static",
    "coverage": "vitest run --coverage --project unit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "version:bump": "node scripts/smart-version-bump.mjs"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./high-scores": {
      "types": "./dist/high-scores.d.ts",
      "import": "./dist/high-scores.js",
      "default": "./dist/high-scores.js"
    },
    "./screen-effects": {
      "types": "./dist/screen-effects.d.ts",
      "import": "./dist/screen-effects.js",
      "default": "./dist/screen-effects.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "API.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE.md",
    "PRIVACY.md",
    "README.md",
    "RELEASE.md",
    "ROADMAP.md",
    "SECURITY.md",
    "SUPPORT.md",
    "WHATSNEW.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/html-vite": "^10.4.1",
    "@types/node": "^25.9.1",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "storybook": "^10.4.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.6"
  }
}
